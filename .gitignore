# =======================
# Environment Variables
# =======================
# NEVER commit .env files — they contain secrets (API keys, passwords)
.env

# =======================
# Python
# =======================
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/

# =======================
# Node / React
# =======================
node_modules/
dist/
build/
.vite/

# =======================
# IDE / Editor
# =======================
.vscode/
.idea/
*.swp
*.swo
*~

# =======================
# OS Files
# =======================
.DS_Store
Thumbs.db
desktop.ini

# =======================
# Logs
# =======================
*.log
npm-debug.log*